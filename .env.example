# LokiVision Environment Configuration

# Application
APP_NAME=LokiVision
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
SECRET_KEY=lokivision-dev-secret-key-change-in-production

# Database
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=lokivision
POSTGRES_USER=lokivision
POSTGRES_PASSWORD=lokivision_dev_password_2024
DATABASE_URL=postgresql+asyncpg://lokivision:lokivision_dev_password_2024@db:5432/lokivision

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=lokivision_redis_password_2024
REDIS_URL=redis://:lokivision_redis_password_2024@redis:6379

# MinIO / S3
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=lokivision_minio_password_2024
MINIO_BUCKET=lokivision-storage
MINIO_SECURE=false

# JWT
JWT_SECRET=lokivision-jwt-secret-min-32-characters-long
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Model Configuration
MODEL_DIR=/app/models
SEGMENTOR_MODEL=yolov8n-blood.pt
MALARIA_MODEL=efficientnet-b0-malaria.pth
SICKLE_MODEL=mobilenetv3-sickle.pth
THAL_MODEL=efficientnet-b2-thal.pth
SEGMENTOR_TYPE=yolov8
DEVICE=cpu

# Inference Settings
MIN_CELLS_FOR_ANALYSIS=50
MALARIA_POSITIVE_THRESHOLD=0.5
SICKLE_POSITIVE_THRESHOLD=0.05
THAL_POSITIVE_THRESHOLD=0.10
GRAD_CAM_MALARIA_THRESHOLD=0.7
GRAD_CAM_SICKLE_THRESHOLD=0.8

# Storage Retention (days)
IMAGE_RETENTION_DAYS=90
CELL_CROP_RETENTION_DAYS=30
REPORT_RETENTION_DAYS=365

# Rate Limiting
RATE_LIMIT_GENERAL=60/minute
RATE_LIMIT_UPLOAD=10/hour
DAILY_ANALYSIS_QUOTA=50

# CORS
ALLOWED_ORIGINS=http://localhost:5173

# MLflow
MLFLOW_TRACKING_URI=http://mlflow:5000

# Monitoring
SENTRY_DSN=
PROMETHEUS_ENABLED=true

# Frontend
VITE_API_URL=http://localhost:8000/api/v1
VITE_WS_URL=ws://localhost:8000/ws